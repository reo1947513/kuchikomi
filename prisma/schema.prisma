generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Agency {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  users     User[]
}

model Industry {
  id        String   @id @default(cuid())
  name      String   @unique
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  loginId      String?  @unique // AG-XXXXXX format
  password     String
  name         String
  phone        String?
  role         String   @default("agent") // "super" | "admin" | "agent"
  shopName     String?
  address      String?
  industry     String?
  agencyId        String?
  contractStart   DateTime?
  contractEnd     DateTime?
  noContractLimit Boolean   @default(false)
  lastAnalysisAt  DateTime?
  agency       Agency?  @relation(fields: [agencyId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?
  stripePriceId        String?
  planType             String?  // "standard" | "premium"
  planReviewLimit      Int      @default(0)
  additionalReviews    Int      @default(0)

  surveys        Survey[]
  contacts       Contact[]
  passwordResets PasswordReset[]
}

model Survey {
  id                  String   @id @default(cuid())
  title               String
  openingMessage      String?  // 冒頭の挨拶文（同意確認含む）
  closingMessage      String?  // 終了挨拶文（お礼・再来店案内）
  completionMessage   String?  // レビュー確認メッセージ（口コミ投稿促進）
  keywords            String?  // キーワード（カンマ区切り）
  selectedToneId      String?
  toneRandom          Boolean  @default(true)
  promptTemplate      String?  // AIプロンプトテンプレート ({tone}, {keywords}, {formattedResponses})
  googleBusinessUrl   String?
  logoUrl             String?
  couponImageUrl      String?
  couponEnabled       Boolean  @default(false)
  couponExpiry        String?
  chatIconType        String?  // "preset" | "logo"
  chatIconPreset      String?  // preset icon name: "home","store","heart","star","smile","utensils","scissors","bone"
  themeMainColor      String?
  themeUserColor      String?
  themeTextColor      String?
  minRandomQuestions  Int      @default(0)
  maxRandomQuestions  Int      @default(0) // 0 = 全質問表示
  isActive            Boolean  @default(true)
  monthlyReviewLimit  Int      @default(100)
  monthlyReviewCount  Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  userId     String
  user       User    @relation(fields: [userId], references: [id])
  questions  Question[]
  sessions   ReviewSession[]
  tones      Tone[]
  advices    Advice[]
}

model Tone {
  id        String  @id @default(cuid())
  name      String  // e.g. "敬体（です・ます調）", "情緒的で感情豊かな表現"
  isActive  Boolean @default(true)
  order     Int     @default(0)
  surveyId  String
  survey    Survey  @relation(fields: [surveyId], references: [id], onDelete: Cascade)
}

model Question {
  id               String    @id @default(cuid())
  text             String
  order            Int
  type             String    @default("choice") // "choice" | "text"
  isRandom         Boolean   @default(false)
  groupName        String?
  surveyId         String
  survey           Survey    @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  parentQuestionId String?
  triggerChoiceId  String?
  parentQuestion   Question? @relation("QuestionBranch", fields: [parentQuestionId], references: [id], onDelete: Cascade)
  branchQuestions  Question[] @relation("QuestionBranch")
  choices          Choice[]
  answers          Answer[]
}

model Choice {
  id         String   @id @default(cuid())
  text       String
  order      Int
  score      Int      @default(0)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model ReviewSession {
  id              String   @id @default(cuid())
  surveyId        String
  survey          Survey   @relation(fields: [surveyId], references: [id])
  answers         Answer[]
  reviewText      String?
  status          String   @default("in_progress") // "in_progress" | "completed"
  isTest          Boolean  @default(false)
  couponUsed      Boolean  @default(false)
  googleClickedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Advice {
  id        String   @id @default(cuid())
  surveyId  String
  survey    Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  content   String
  dateFrom  String?
  dateTo    String?
  createdAt DateTime @default(now())
}

model Answer {
  id         String        @id @default(cuid())
  sessionId  String
  session    ReviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId String
  question   Question      @relation(fields: [questionId], references: [id])
  choiceId   String?
  textValue  String?
  createdAt  DateTime      @default(now())
}

model Contact {
  id             String   @id @default(cuid())
  category       String
  contractStatus String
  companyName    String
  lastName       String
  firstName      String
  email          String
  phone          String
  content        String
  source         String   @default("dashboard") // "dashboard" | "hp"
  status         String   @default("未対応")
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])
  createdAt      DateTime @default(now())
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String
  category    String   @default("お知らせ") // "新機能" | "メンテナンス" | "お知らせ" | "重要"
  isPublished Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Campaign {
  id          String   @id @default(cuid())
  title       String
  content     String
  target      String   @default("all") // "all" | "free" | "paid" | "cancelled"
  isPublished Boolean  @default(true)
  emailSent   Boolean  @default(false)
  emailSentAt DateTime?
  startAt     DateTime @default(now())
  endAt       DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CaseStudy {
  id          String   @id @default(cuid())
  shopName    String
  industry    String
  title       String
  content     String
  result      String
  rating      Int      @default(5)
  isPublished Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
